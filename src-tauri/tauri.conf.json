{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codrax",
  "version": "0.1.1",
  "identifier": "com.codrax.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Codrax",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "maximized": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQ1MzAzN0NFNzEyMTE0NTgKUldSWUZDRnh6amN3MVMvZzc4N29nZ293aEJGdHVYdGIxUURVWnVCYnptelc2NEhmZ28zTmpMY0wK",
      "endpoints": [
        "https://github.com/Qliphr/Codrax/releases/latest/download/latest.json"
      ]
    }
  }
}
